# Keycloak Postgres (port 5433 — separate from the app database)
KC_DB_PASSWORD=replace-with-a-strong-password

# Keycloak admin console credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-a-strong-password

# Test user for Vitest integration tests (see infra/local/README.md for setup)
KC_TEST_USER=testuser@bbc.dev
KC_TEST_PASSWORD=replace-with-test-user-password

# -----------------------------------------------------------------------
# NOTE: BFF client secrets are baked into infra/keycloak/bbc-realm.json
# as dev-only placeholder values. Before deploying to staging or prod,
# rotate these secrets via the Keycloak admin console or managed service
# UI and update the secrets in each BFF service's environment config.
#
# Dev placeholder values (match realm JSON defaults):
#   mobile-bff  client secret: dev-mobile-bff-secret
#   coach-bff   client secret: dev-coach-bff-secret
# -----------------------------------------------------------------------
